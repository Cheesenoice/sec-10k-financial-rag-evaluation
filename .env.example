# ─────────────────────────────────────────────
# LLM API Keys
# ─────────────────────────────────────────────

# Groq API (free tier tại https://console.groq.com)
# Dùng cho LLM generation trong pipeline chính
GROQ_API_KEY=your_groq_api_key_here

# Gemini API (Google AI Studio - free/pay-as-you-go tại https://aistudio.google.com)
# Dùng để generate ground truth dataset và LLM alternative
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────
# Model Configuration
# ─────────────────────────────────────────────

# LLM models
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-3.1-flash-lite

# Embedding model (sẽ download tự động từ HuggingFace)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Reranker model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─────────────────────────────────────────────
# Pipeline Configuration
# ─────────────────────────────────────────────

# Chunking
CHUNK_SIZE_DEFAULT=512
CHUNK_OVERLAP_DEFAULT=64
CHUNK_SIZE_SMALL=256     # Item 1A - Risk Factors
CHUNK_SIZE_LARGE=512     # Item 7 - MD&A

# Retrieval
BM25_TOP_K=20
VECTOR_TOP_K=20
RRF_K=60                 # Reciprocal Rank Fusion constant
RERANK_TOP_K=5           # Final docs sent to LLM

# ─────────────────────────────────────────────
# SEC EDGAR Configuration
# ─────────────────────────────────────────────

# Theo SEC policy: phải có User-Agent header
SEC_USER_AGENT=YourName your@email.com

# ─────────────────────────────────────────────
# Paths
# ─────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_INDEXES_DIR=data/indexes
DATA_EVAL_DIR=data/eval
EVAL_RESULTS_DIR=eval/results
EVAL_FIGURES_DIR=eval/figures
